{
  "manifest_version": 3,
  "name": "Tab Scraper",
  "description": "A Chrome extension to scrape all urls from open tabs and download them as a text file.",
  "version": "1.1.0",

  "permissions": ["tabs", "downloads", "storage", "scripting", "activeTab"],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },

  "action": {
    "default_popup": "public/html/popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },

  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}