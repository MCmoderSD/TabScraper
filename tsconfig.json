{
  "compilerOptions": {

    /* Language */
    "target": "ESNext",
    "lib": ["ESNext", "DOM"],

    /* Modules */
    "module": "ESNext",
    "moduleResolution": "node",
    "isolatedModules": true,
    "resolveJsonModule": true,

    /* Paths */
    "rootDir": "src",
    "outDir": "dist",

    /* Type checking */
    "strict": true,
    "noImplicitAny": true,
    "noEmitOnError": true,

    /* Interop */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    /* Chrome extension types */
    "types": ["chrome"],

    /* Quality of life */
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    /* Debugging */
    "sourceMap": true
  },
  "include": ["src"]
}